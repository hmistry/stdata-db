{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "declaration": false,
    "sourceMap": true,
    "outDir": "./assets/js",
    "rootDir": "./assets/js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler"
  },
  "include": ["assets/js/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
